# ==========================================================
# NekoPlayer 开发环境配置
# 复制本文件为 .env.local，填入你自己的 Emby 服务器信息
#   cp .env.local.example .env.local
# ==========================================================

# 【必填】Emby 服务器地址（含端口）
# Vite 会把前端的 /emby 请求代理转发到这里，解决浏览器跨域
VITE_EMBY_URL=http://192.168.1.10:8096

# 【可选】默认登录账号密码（留空则在界面里手动输入）
VITE_EMBY_USERNAME=
VITE_EMBY_PASSWORD=
